{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "GeneralCoder",
  "mcp": {
    "backlog": {
      "type": "local",
      "command": ["backlog", "mcp", "start"]
    }
  },
  "plugin": ["./plugins/opencode-context-cache.mjs"],
  "provider": {
    "pythagoras": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (pythagoras)",
      "options": {
        "baseURL": "http:/192.168.0.11:11434/v1"
      },
      "models": {
        "gemma4:26b": {
          "name": "Gemma 4"
        },
        "qwen3.6:35b-a3b": {
          "name": "Qwen 3.6"
        }
      }
    }
  }
}
